# ── 构建 sina-real-time 采集器 ──
FROM rust:1.78-slim AS build
WORKDIR /build
COPY Cargo.toml Cargo.lock* ./
COPY src/ ./src/
RUN cargo build --release

# ── 运行环境 ──
FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build /build/target/release/sina-realtime-collector .
COPY stocks_100.txt stocks_1000.txt ./
EXPOSE 0
CMD ["./sina-realtime-collector", "--stocks", "stocks_100.txt", "--output", "/app/data"]
